# Day 8

Java For Loop Practice

public class PrintNumbers {
    public static void main(String[] args) {

        for (int i = 1; i <= 10; i++) {
            System.out.println(i);
        }

    }
}
public class EvenNumbers {
    public static void main(String[] args) {

        for (int i = 2; i <= 20; i = i + 2) {
            System.out.println(i);
        }

    }
}
